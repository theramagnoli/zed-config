{
    "theme": {
        "dark": "macOS Classic Dark",
        "light": "macOS Classic Light",
        "mode": "light"
    },
    "icon_theme": {
        "dark": "Colored Zed Icons Theme Dark",
        "light": "Colored Zed Icons Theme Light",
        "mode": "dark"
    },
    "ui_font_family": "Monaspace Radon",
    "ui_font_size": 13.0,
    "ui_font_weight": 400.0,
    "buffer_font_family": "Monaspace Radon",
    "buffer_font_features": {
        "calt": true,
        "clig": true,
        "liga": true
    },
    "buffer_font_size": 11.5,
    "buffer_font_weight": 400.0,
    "buffer_line_height": {
        "custom": 2
    },
    "agent_buffer_font_size": 11.5,
    "agent_ui_font_size": 13,
    "text_rendering_mode": "platform_default",
    "agent": {
        "auto_compact": {
            "threshold": "70%"
        },
        "commit_message_instructions": "Genera un único mensaje de commit en español a partir de los cambios realizados.\n\nPrimero identifica la intención principal del cambio, no te limites a enumerar archivos, funciones o líneas modificadas. El mensaje debe explicar qué comportamiento, funcionalidad o estructura se agregó, corrigió, modificó o eliminó.\n\nASUNTO OBLIGATORIO\n- Debe comenzar exactamente con: Se\n- Formato: Se + verbo en tercera persona del singular + actividad concreta\n- Usa verbos como: agrega, implementa, corrige, modifica, actualiza, elimina, refactoriza, ajusta, integra, reemplaza o configura\n- Usa presente indicativo; no uses infinitivos ni participios\n- Describe el resultado o propósito del cambio, no solamente la acción técnica realizada\n- Prioriza el cambio funcional más importante cuando existan varios cambios relacionados\n- Longitud recomendada: entre 40 y 90 caracteres\n- No uses punto final\n- No uses prefijos como feat:, fix:, refactor: o chore:\n- No menciones nombres de archivos salvo que sean indispensables para entender el cambio\n- No uses asuntos genéricos como:\n  - Se realizan cambios\n  - Se actualizan archivos\n  - Se corrigen errores\n  - Se hacen ajustes\n  - Se modifica código\n\nCUERPO OPCIONAL\nIncluye un cuerpo únicamente cuando ocurra al menos una de estas condiciones:\n- Existen dos o más cambios relevantes que no caben claramente en el asunto\n- Es necesario explicar una decisión técnica importante\n- El cambio afecta distintas capas, módulos o comportamientos\n- Hay una consecuencia relevante que no resulta evidente en el asunto\n\nReglas para el cuerpo:\n- Separa el asunto y el cuerpo con una línea en blanco\n- Usa una lista con guiones\n- Incluye como máximo 4 puntos\n- Cada punto debe describir un cambio concreto o su propósito\n- No repitas ni reformules el asunto\n- No enumeres cambios irrelevantes, formateos o detalles internos menores\n\nCRITERIOS DE REDACCIÓN\n- El mensaje completo debe estar en español\n- Se permiten términos técnicos comunes en inglés, como endpoint, middleware, snapshot, join, payload, hook o cache\n- Conserva nombres propios de clases, métodos, endpoints, tablas y tecnologías cuando sean necesarios\n- Evita explicar cómo se modificó cada línea; resume qué se consiguió con el cambio\n- No inventes funcionalidades, causas ni resultados que no puedan deducirse de los cambios\n- Si los cambios son principalmente una corrección, usa corrige o ajusta e indica exactamente qué comportamiento se solucionó\n- Si los cambios reorganizan código sin alterar comportamiento, usa refactoriza\n- Si los cambios incluyen funcionalidad y refactorización, prioriza la funcionalidad en el asunto y menciona la refactorización en el cuerpo solo si es relevante\n\nEJEMPLOS CORRECTOS\nSe agrega envío de metadatos a POK\n\nSe corrige validación de fechas en reservaciones de lockers\n\nSe integra autorización por grupos para crear secciones\n\nSe actualiza cálculo del estado de los registros de lockers\n\nSe agrega búsqueda de usuarios por nombre y matrícula\n\n- Se normaliza el texto mediante unaccent\n- Se conserva el ordenamiento por coincidencia\n\nEJEMPLOS INCORRECTOS\nSe realizan varios cambios\nSe modifican archivos del controlador\nSe actualiza código y se corrigen errores\nAgregar validación de usuarios\nCambios en lockers\nfix: se corrige formulario\n\nSALIDA\nDevuelve exclusivamente el mensaje final del commit.\nNo incluyas explicaciones, encabezados, comillas, bloques de código, metacomentarios ni el diff original.",
        "commit_message_model": {
            "effort": "medium",
            "enable_thinking": true,
            "model": "gpt-5.6-terra",
            "provider": "openai-subscribed"
        },
        "default_model": {
            "effort": "medium",
            "enable_thinking": true,
            "model": "gpt-5.6-sol",
            "provider": "openai-subscribed"
        },
        "dock": "right",
        "favorite_models": [
            {
                "effort": "medium",
                "enable_thinking": true,
                "model": "gpt-5.6-sol",
                "provider": "openai-subscribed"
            },
            {
                "effort": "high",
                "enable_thinking": true,
                "model": "gpt-5.6-terra",
                "provider": "openai-subscribed"
            },
            {
                "effort": "high",
                "enable_thinking": true,
                "model": "deepseek-v4-pro",
                "provider": "deepseek"
            }
        ],
        "sandbox_permissions": {
            "network_hosts": [
                "docs.pok.tech",
                "api.pok.tech",
                "help.pok.tech",
                "lucid.adonisjs.com",
                "html.duckduckgo.com",
                "www.pok.tech",
                "www.google.com"
            ]
        },
        "tool_permissions": {
            "default": "allow"
        }
    },
    "agent_servers": {
        "codex-acp": {
            "default_config_options": {
                "fast-mode": false,
                "mode": "agent-full-access",
                "model": "gpt-5.6-sol",
                "reasoning_effort": "medium"
            },
            "type": "registry"
        },
        "grok-build": {
            "type": "registry"
        },
        "opencode": {
            "default_config_options": {
                "model": "opencode-go/glm-5.2"
            },
            "type": "registry"
        }
    },
    "centered_layout": {
        "left_padding": 0.165,
        "right_padding": 0
    },
    "collaboration_panel": {
        "button": false,
        "dock": "right"
    },
    "context_servers": {},
    "cursor_blink": true,
    "cursor_shape": "block",
    "debugger": {
        "button": true,
        "timeout": 10000
    },
    "diagnostics": {
        "inline": {
            "enabled": true,
            "min_column": 80
        }
    },
    "diff_view_style": "unified",
    "disable_ai": false,
    "edit_predictions": {
        "copilot": {
            "enable_next_edit_suggestions": false
        },
        "mode": "eager",
        "provider": "copilot"
    },
    "excerpt_context_lines": 6,
    "expand_excerpt_lines": 10,
    "file_finder": {
        "file_icons": true,
        "include_ignored": "indexed",
        "modal_max_width": "full"
    },
    "file_types": {
        "XML": [
            "wsdl",
            "xsd",
            "xaml"
        ]
    },
    "format_on_save": "on",
    "formatter": "prettier",
    "git": {
        "branch_picker": {
            "show_author_name": true
        }
    },
    "git_panel": {
        "dock": "right",
        "tree_view": false
    },
    "gutter": {
        "breakpoints": true,
        "folds": false,
        "line_numbers": true,
        "min_line_number_digits": 5,
        "runnables": false
    },
    "hard_tabs": false,
    "hide_mouse": "never",
    "indent_guides": {
        "active_line_width": 3,
        "background_coloring": "disabled",
        "coloring": "fixed",
        "enabled": true,
        "line_width": 1
    },
    "inlay_hints": {
        "enabled": false,
        "show_background": true,
        "show_type_hints": true
    },
    "language_models": {
        "opencode": {
            "show_free_models": false,
            "show_go_models": true,
            "show_zen_models": false
        }
    },
    "languages": {
        "CSS": {
            "language_servers": [
                "tailwindcss-language-server",
                "vscode-css-language-server"
            ],
            "prettier": {
                "allowed": true,
                "plugins": [
                    "@prettier/plugin-xml"
                ]
            }
        },
        "Markdown": {
            "show_edit_predictions": true
        },
        "Python": {
            "format_on_save": "on",
            "formatter": [
                {
                    "code_action": "source.organizeImports.ruff"
                },
                {
                    "code_action": "source.fixAll.ruff"
                },
                {
                    "language_server": {
                        "name": "ruff"
                    }
                }
            ],
            "language_servers": [
                "pylsp",
                "ruff",
                "!pyright",
                "..."
            ]
        },
        "TypeScript": {
            "show_edit_predictions": true,
            "tab_size": 4
        },
        "Vue.js": {
            "language_servers": [
                "vtsls",
                "vue-language-server",
                "tailwindcss-language-server"
            ]
        },
        "XML": {
            "prettier": {
                "allowed": true,
                "plugins": [
                    "@prettier/plugin-xml"
                ]
            }
        },
        "lsp": {
            "pylsp": {
                "settings": {
                    "plugins": {
                        "autopep8": {
                            "enabled": false
                        },
                        "black": {
                            "enabled": false
                        },
                        "flake8": {
                            "enabled": false
                        },
                        "isort": {
                            "enabled": false
                        },
                        "jedi": {
                            "enabled": true
                        },
                        "mccabe": {
                            "enabled": false
                        },
                        "pycodestyle": {
                            "enabled": false
                        },
                        "pydocstyle": {
                            "enabled": false
                        },
                        "pyflakes": {
                            "enabled": false
                        },
                        "pylint": {
                            "enabled": false
                        },
                        "pylsp_mypy": {
                            "enabled": true
                        },
                        "rope": {
                            "enabled": true
                        },
                        "rope_autoimport": {
                            "enabled": true
                        },
                        "rope_completion": {
                            "enabled": true
                        },
                        "ruff": {
                            "enabled": false
                        },
                        "yapf": {
                            "enabled": false
                        }
                    }
                }
            },
            "ruff": {
                "initialization_options": {
                    "settings": {
                        "codeAction": {
                            "disableRuleComment": {
                                "enable": false
                            },
                            "fixViolation": {
                                "enable": true
                            }
                        },
                        "configuration": {
                            "format": {
                                "quote-style": "double",
                                "skip-magic-trailing-comma": false
                            }
                        },
                        "configurationPreference": "filesystemFirst",
                        "fixAll": true,
                        "format": {
                            "preview": true
                        },
                        "lineLength": 100,
                        "lint": {
                            "enable": true,
                            "extendSelect": [
                                "I"
                            ],
                            "select": [
                                "E4",
                                "E7",
                                "E9",
                                "F"
                            ]
                        },
                        "organizeImports": true,
                        "showSyntaxErrors": true
                    }
                }
            }
        }
    },
    "lsp": {
        "vscode-css-language-server": {
            "settings": {
                "css": {
                    "lint": {
                        "unknownAtRules": "ignore"
                    }
                }
            }
        },
        "vtsls": {
            "enable_lsp_tasks": true,
            "settings": {
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always"
                    }
                },
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always"
                    }
                }
            }
        }
    },
    "max_tabs": 5,
    "minimum_contrast_for_highlights": 90.0,
    "outline_panel": {
        "dock": "right"
    },
    "preferred_line_length": 80,
    "preview_tabs": {
        "enable_preview_from_file_finder": false,
        "enabled": true
    },
    "project_panel": {
        "bold_folder_labels": true,
        "dock": "right",
        "entry_spacing": "standard",
        "hide_root": false,
        "indent_size": 30
    },
    "restore_on_startup": "last_workspace",
    "rounded_selection": true,
    "scrollbar": {
        "axes": {
            "horizontal": false
        },
        "diagnostics": "error",
        "selected_text": true
    },
    "show_edit_predictions": true,
    "tab_bar": {
        "show": true,
        "show_nav_history_buttons": false,
        "show_tab_bar_buttons": false
    },
    "tab_size": 4,
    "tabs": {
        "close_position": "right",
        "file_icons": false,
        "git_status": true,
        "show_diagnostics": "off"
    },
    "terminal": {
        "blinking": "on",
        "dock": "right",
        "line_height": "standard"
    },
    "title_bar": {
        "show_menus": false,
        "show_user_menu": true,
        "show_user_picture": true
    },
    "toolbar": {
        "agent_review": true,
        "breadcrumbs": true,
        "code_actions": true,
        "quick_actions": false,
        "selections_menu": true
    },
    "unnecessary_code_fade": 0.3,
    "when_closing_with_no_tabs": "keep_window_open"
}
